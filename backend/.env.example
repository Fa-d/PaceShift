# PaceShift backend environment.
#
# Copy to `.env` and fill in secrets for `docker compose` (which auto-loads a
# `.env` in this directory), or export them in your shell. `.env` is gitignored.
# For local dev the defaults below are fine EXCEPT the secrets flagged REQUIRED.
#
# The recommended local flow keeps GLM_API_KEY in the macOS Keychain and injects
# it via `backend/scripts/compose.sh` rather than committing it here — see that
# script. This file documents every var the backend reads (see Config.kt).

# ---- Server ----
PORT=8080

# ---- Postgres ----
# Under docker compose the api service uses the `db` host; override here only
# for host-based runs (e.g. ./gradlew run).
DATABASE_URL=jdbc:postgresql://db:5432/paceshift
DATABASE_USER=paceshift
DATABASE_PASSWORD=paceshift

# ---- Auth (JWT) ----
JWT_SECRET=dev-secret-change-me   # REQUIRED in prod — use a long random secret.
JWT_ISSUER=paceshift
JWT_AUDIENCE=paceshift-app
ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=30

# ---- OAuth (validate provider ID tokens; set in prod) ----
GOOGLE_CLIENT_IDS=
APPLE_CLIENT_IDS=com.paceshift.app

# ---- RevenueCat (billing webhook) ----
REVENUECAT_AUTH_TOKEN=
PRO_ENTITLEMENT_ID=pro

# ---- AI: Claude (legacy — currently unused) ----
# /ai/explain and /ai/chat now route through GLM (below), so these are unused.
# Kept for reference / a future switch back to Anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ---- AI: GLM 5.2 (Phase 12 — /ai/ui generative UI) ----
# REQUIRED for generative-UI surfaces; /ai/ui returns 503 until GLM_API_KEY is set.
# glm-5.2 needs a funded Z.ai account; set GLM_MODEL=glm-4.5-flash for the free tier.
GLM_API_KEY=
GLM_BASE_URL=https://api.z.ai/api/paas/v4
GLM_MODEL=glm-5.2
# GLM 4.5/5.2 are reasoning models. Leave reasoning disabled: with it ON they burn
# the whole token budget on hidden reasoning and return empty content (and are slow
# enough to trip the HTTP timeout). Set false only on a model where you want it.
GLM_DISABLE_THINKING=true
