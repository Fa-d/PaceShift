<?xml version="1.0" encoding="utf-8"?>
<!--
  DEBUG builds only (this file lives under src/debug). Permits cleartext HTTP so
  the app can reach a local development backend on your LAN — e.g.
  http://192.168.0.213:8080. Release builds do NOT use this config and stay
  HTTPS-only.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
