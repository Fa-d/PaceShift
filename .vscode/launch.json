{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "PaceShift (physical device → Mac LAN backend)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--dart-define=API_BASE_URL=http://192.168.0.213:8080"
      ]
    },
    {
      "name": "PaceShift (Android emulator → local backend)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--dart-define=API_BASE_URL=http://10.0.2.2:8080"
      ]
    },
    {
      "name": "PaceShift (iOS simulator → local backend)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--dart-define=API_BASE_URL=http://localhost:8080"
      ]
    },
    {
      "name": "PaceShift (custom API host)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--dart-define=API_BASE_URL=${input:apiBaseUrl}"
      ]
    }
  ],
  "inputs": [
    {
      "id": "apiBaseUrl",
      "type": "promptString",
      "description": "Backend base URL (e.g. http://192.168.0.213:8080)",
      "default": "http://192.168.0.213:8080"
    }
  ]
}
